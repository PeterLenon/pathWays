# ─── LLM ───────────────────────────────────────────────────────────────────────

# Primary: Ollama running locally in Docker.
# Start with: docker compose up -d
# Pull model: docker exec incomepath-ollama ollama pull qwen2.5:14b
# Then set this to the host where Ollama is reachable:
OLLAMA_HOST=http://localhost:11434

# Fallback: Groq (cloud, free tier). Used when OLLAMA_HOST is not set.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here


# ─── External Data APIs ─────────────────────────────────────────────────────────

# BLS Public Data API — free, but a key raises the daily limit from 500 to 50k.
# Register at: https://data.bls.gov/registrationEngine/
# Leave blank to use the anonymous tier (500 queries/day — sufficient for dev).
BLS_API_KEY=

# Adzuna job postings API — free tier: 1,000 calls/month.
# Register at: https://developer.adzuna.com
# Leave blank to disable live job demand enrichment (pipeline degrades gracefully).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=


# ─── Supabase ───────────────────────────────────────────────────────────────────

# Get these from your Supabase project dashboard under Settings → API.
# The anon key is safe to expose publicly — RLS enforces data access.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here


# ─── App ────────────────────────────────────────────────────────────────────────

# Used by the sign-out redirect. Set to your deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
